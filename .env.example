OCI_GENAI_REGION=us-chicago-1
OCI_GENAI_PROJECT_OCID=ocid1.generativeaiproject.oc1.us-chicago-1.example
OCI_GENAI_MODEL=openai.gpt-oss-120b

# For local development only:
# OCI_GENAI_AUTH=session
# OCI_CLI_PROFILE=DEFAULT

# For OCI Compute instances, use instance principals:
OCI_GENAI_AUTH=instance_principal

# Stable demo default:
# Basic chat uses OCI Conversations memory. Function Calling and Code
# Interpreter are isolated from the long-lived OCI conversation by default to
# avoid provider-side validation issues when tool calls replay prior messages.
# Set true only when explicitly testing tool calls attached to Conversations.
OCI_AGENT_ATTACH_TOOLS_TO_CONVERSATION=false
